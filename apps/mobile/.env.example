# For iOS Simulator: use your Mac's LAN IP (e.g. 192.168.1.x)
# Run: ipconfig getifaddr en0   to find it
# For device/TestFlight: use your deployed Railway URL
EXPO_PUBLIC_API_URL=http://192.168.1.x:8000
EXPO_PUBLIC_WS_URL=ws://192.168.1.x:8000

# Expo EAS project UUID — find it at expo.dev after running: eas init
# Required for push notifications on physical devices
EXPO_PUBLIC_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_UUID

# Optional — Sentry error tracking
SENTRY_DSN=
